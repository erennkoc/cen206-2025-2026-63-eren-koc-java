@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(admin, "Project Manager", "A user of the Project Management console tool.")

System_Boundary(c1, "Project Management Ecosystem") {
    Container(app, "Console Interface App", "Java 1.8 (JLine3)", "Main business logic layer handling interactions via CLI.")
    
    ContainerDb(bin_db, "Binary System", ".dat files", "Persists User, Project, and Task logs locally in serialized binary.")
    ContainerDb(sqlite_db, "SQLite System", "projectmanager.db", "Stores normalized relational data seamlessly on the local machine.")
    ContainerDb(mysql_db, "MySQL System", "Docker MySQL 8", "Handles relational storage via external remote service configurations.")
}

Rel(admin, app, "Uses", "Keyboard/CLI")
Rel(app, bin_db, "Reads from / Writes to", "Java.io ObjectStreams")
Rel(app, sqlite_db, "Reads from / Writes to", "JDBC API")
Rel(app, mysql_db, "Reads from / Writes to", "JDBC API")

@enduml
